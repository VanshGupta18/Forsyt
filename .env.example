# ─── PostgreSQL ───────────────────────────────────────────────────────────────
PG_DSN=postgresql://india_ai:secret@localhost:5432/india_ai_gpr
PG_PASSWORD=secret

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── OpenAI (GPT-4o-mini Stage 2 extractor) ──────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ─── API authentication ───────────────────────────────────────────────────────
# Generate: python -c "import hashlib; print(hashlib.sha256(b'your_raw_key').hexdigest())"
API_KEY_HASH=your_sha256_hash_here

# Set to "true" to bypass auth for local development
DEV_MODE=false

# ─── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ─── GPR pipeline tunables ────────────────────────────────────────────────────
DECAY_LAMBDA=0.10
BLACKOUT_THRESHOLD_PCT=0.20
GPR_NORM_WINDOW=252

# ─── API URL (used by verify_pipeline.py) ─────────────────────────────────────
API_URL=http://localhost:8000
API_KEY=your_raw_api_key_here
