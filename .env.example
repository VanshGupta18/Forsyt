# Newsemble Environment Variables
# Copy this file to .env and fill in the values.

# PostgreSQL connection string (required for production)
# Get this from Supabase: Project Settings > Database > Connection String (URI)
# Use the "Transaction" pooler connection on port 6543 for best performance.
# Example: postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Scrape interval in seconds (default: 86400 = once per day)
# Set to 0 to disable background scraping in the web service
SCRAPE_INTERVAL=86400

# Flask settings
FLASK_ENV=production
